# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # never expose to browser

# Upstash Redis — get from Upstash console → REST API
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# Paddle — server-side only (never expose to browser)
PADDLE_API_KEY=
PADDLE_PRICE_MONTHLY=
PADDLE_PRICE_YEARLY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox   # omit or set to "production" for live

# App URL — used for Paddle checkout redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000
